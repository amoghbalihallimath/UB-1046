rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────
    // Citizens can read/write their own user doc.
    // Admins can read any user doc.
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         request.auth.token.email == 'jansevaaiportal@gmail.com');
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ── Complaints ───────────────────────────────────────────
    // Citizens: create complaints under their uid.
    //           Read only their own complaints.
    // Admins: full read + update (no delete).
    match /complaints/{complaintId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         request.auth.token.email == 'jansevaaiportal@gmail.com');

      allow update: if request.auth != null &&
        request.auth.token.email == 'jansevaaiportal@gmail.com';

      allow delete: if false; // No deletions allowed
    }
  }
}
